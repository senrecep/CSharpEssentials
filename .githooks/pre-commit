#!/usr/bin/env bash
# pre-commit: Validates that README.MD badge counts match actual values.
# Setup: git config core.hooksPath .githooks

set -euo pipefail

README="README.MD"
MISMATCH=0

# ── Test count ─────────────────────────────────────────────────────────────────
ACTUAL_TESTS=$(grep -r "\[Fact\]\|\[Theory\]" CSharpEssentials.Tests/ --include="*.cs" | wc -l | tr -d ' ')
BADGE_TESTS=$(grep -oE 'tests-[0-9]+%20passing' "$README" | sed 's/tests-\([0-9]*\)%20passing/\1/' || echo "")

if [ -z "$BADGE_TESTS" ]; then
    echo "⚠️  README.MD: tests badge not found — skipping auto-fix."
    MISMATCH=1
elif [ "$ACTUAL_TESTS" != "$BADGE_TESTS" ]; then
    echo "🔧 Auto-fixing tests badge: $BADGE_TESTS → $ACTUAL_TESTS"
    sed -i '' "s/tests-[0-9]*%20passing/tests-${ACTUAL_TESTS}%20passing/" "$README"
    git add "$README"
fi

# ── Package count ──────────────────────────────────────────────────────────────
ACTUAL_PACKAGES=$(find . -maxdepth 2 -name "CSharpEssentials.*.csproj" -o -name "CSharpEssentials.csproj" \
    | grep -v -E "Tests|examples|Examples" \
    | wc -l | tr -d ' ')
BADGE_PACKAGES=$(grep -oE 'packages-[0-9]+-blue' "$README" | grep -oE '[0-9]+' || echo "")

if [ -z "$BADGE_PACKAGES" ]; then
    echo "⚠️  README.MD: packages badge not found — skipping auto-fix."
    MISMATCH=1
elif [ "$ACTUAL_PACKAGES" != "$BADGE_PACKAGES" ]; then
    echo "🔧 Auto-fixing packages badge: $BADGE_PACKAGES → $ACTUAL_PACKAGES"
    sed -i '' "s/packages-[0-9]*-blue/packages-${ACTUAL_PACKAGES}-blue/" "$README"
    git add "$README"
fi

# ── Result ─────────────────────────────────────────────────────────────────────
if [ "$MISMATCH" -eq 1 ]; then
    echo ""
    echo "Could not auto-fix one or more badges — please update README.MD manually."
    exit 1
fi

exit 0
